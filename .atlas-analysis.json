  "keyFeatures": [
    "Multi-organization fundraising campaigns",
    "Real-time order management and tracking",
    "Flexible payment verification (Venmo, other methods)",
    "Pickup event scheduling and QR code generation",
    "Referral program for tracking campaign ambassadors",
    "Role-based access control (buyers and sellers)",
    "Image upload and management for fundraisers and items",
    "Email notifications via Mailgun",
    "Type-safe API contracts with shared Zod schemas"
  ],
  "publicApiSurface": [
    "GET /api/fundraiser - List all fundraisers",
    "GET /api/fundraiser/:id - Get fundraiser details",
    "POST /api/fundraiser - Create fundraiser (authenticated)",
    "PUT /api/fundraiser/:id - Update fundraiser (authenticated)",
    "DELETE /api/fundraiser/:id - Delete fundraiser (authenticated)",
    "POST /api/order - Create order (authenticated)",
    "GET /api/order - Get user orders (authenticated)",
    "GET /api/order/:id - Get order details (authenticated)",
    "PUT /api/order/:id - Update order status (authenticated)",
    "GET /api/organization - List organizations",
    "POST /api/organization - Create organization (authenticated)",
    "PUT /api/organization/:id - Update organization (authenticated)",
    "GET /api/user/me - Get current user (authenticated)",
    "POST /api/email/invite - Send invitation email (authenticated)"
  ]
